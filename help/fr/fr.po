msgid "Spreadsheets"
msgstr "Feuilles de calcul"

#
#. (itstool) path: section/p
#: C/import.page:38
msgid ""
"Graphs supports importing data from .ods and .xlsx spreadsheet files. The X "
"and Y columns are selected by their alphabetical column index, starting from "
"zero. As with column-based files, the <em>Single Column</em> option can be "
