msgid "Graphs"
msgstr "Graphes"

#: data/se.sjoerd.Graphs.metainfo.xml.in:44
msgid "Plot and manipulate any data"
msgstr "Tracer et manipuler toute donnée"

#: data/se.sjoerd.Graphs.metainfo.xml.in:48
