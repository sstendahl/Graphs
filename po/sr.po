#: data/ui/transform.blp:41
msgid ""
"<b>Available variables</b>\n"
"General:\n"
" counts - number of data points\n"
"\n"
"X-Axis:\n"
" x_min, x_max - minimum and maximum values,\n"
" x_mean, x_median - average and median,\n"
" x_std, x_sum — standard deviation and sum\n"
"\n"
"Y-Axis:\n"
" y_min, y_max - minimum and maximum,\n"
" y_mean, y_median — average and median,\n"
" y_std, y_sum - standard deviation and sum\n"
"\n"
"Trigonometric functions use radians by default.\n"
"Append d to use degrees, e.g. sind(x) or cosd(x)."
msgstr ""
"<b>Доступне променљиве</b>\n"
"Опште:\n"
" counts — број тачака података\n"
"\n"
"X-оса:\n"
" x_min, x_max — најмања и највећа вредност,\n"
" x_mean, x_median — просек и медијана,\n"
" x_std, x_sum — стандардно одступање и збир\n"
"\n"
"Y-оса:\n"
" y_min, y_max — најмања и највећа вредност,\n"
" y_mean, y_median — просек и медијана,\n"
" y_std, y_sum — стандардно одступање и збир\n"
"\n"
"Тригонометријске функције подразумевано користе радијане.\n"
"Додајте „d“ да користите степене, нпр. sind(x) или cosd(x)."

