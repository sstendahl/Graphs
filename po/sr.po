#: data/ui/import/columns/item-group.blp:72 data/ui/import/spreadsheet/item-group.blp:72
msgid ""
"<b>X Value Calculation</b>\n"
"\n"
"Enter an equation to calculate X values.\n"
"Use 'n' for the row index (starting from 0).\n"
"\n"
"<b>Examples:</b>\n"
"• <b>n</b> → 0, 1, 2, 3, 4...\n"
"• <b>n*0.5</b> → 0, 0.5, 1.0, 1.5, 2.0...\n"
"• <b>n^2</b> → 0, 1, 4, 9, 16...\n"
"• <b>2^n</b> → 1, 2, 4, 8, 16...\n"
"• <b>n*10+100</b> → 100, 110, 120, 130..."
msgstr ""
"<b>Израчунавање икс вредности</b>\n"
"\n"
"Унесите једначину за израчунавање икс вредности.\n"
"Користите „n“ за индекс реда (почиње од 0).\n"
"\n"
"<b>Примери:</b>\n"
"• <b>n</b> → 0, 1, 2, 3, 4...\n"
"• <b>n*0.5</b> → 0, 0.5, 1.0, 1.5, 2.0...\n"
"• <b>n^2</b> → 0, 1, 4, 9, 16...\n"
"• <b>2^n</b> → 1, 2, 4, 8, 16...\n"
"• <b>n*10+100</b> → 100, 110, 120, 130..."

